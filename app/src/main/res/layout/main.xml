<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/button_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/go_compose"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_data_binding"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Data Binding"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_data_binding_artboards"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Data Binding Artboards"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_data_binding_images"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Data Binding Images"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_data_binding_lists"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Data Binding Lists"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_layout"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Layout"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_audio"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Audio"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_capped_fps"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Capped FPS"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_touch_pass_through"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Touch Pass Through"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_compose_scrolling"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Compose Scrolling"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_scripting"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Scripting"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_rive_snapshot"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Rive Snapshot"
                android:textColor="@color/textColorPrimary" />

            <Button
                android:id="@+id/go_hardware_bitmap_canvas"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Hardware Bitmap Canvas"
                android:textColor="@color/textColorPrimary" />

        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
